# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tg_content_engine

# Redis
REDIS_URL=redis://localhost:6379/0

# Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Encryption (for settings)
ENCRYPTION_KEY=your-fernet-encryption-key-here

# External APIs (stubbed for development)
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=AIza-your-key-here
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_SMM_CHAT_ID=123456789

# Timezone
APP_TIMEZONE=Asia/Dubai

# Scraping
SCRAPE_USER_AGENT=Mozilla/5.0 (compatible; TGContentBot/1.0)
SCRAPE_REQUEST_DELAY_SEC=2

# App Settings
DEBUG=true
CORS_ORIGINS=http://localhost:3000
